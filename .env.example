# Environment Variables Configuration
# Copy this file to .env.local and fill in your actual values

# Google Tag Manager
# Get your GTM ID from: https://tagmanager.google.com/
# Format: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Analytics 4 (GA4)
# Note: GA4 should be configured through GTM, not directly here
# This is just for reference if needed
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Production URL (used for canonical tags and sitemaps)
NEXT_PUBLIC_SITE_URL=https://elchicanopocket.com.br

# Contact Information
NEXT_PUBLIC_WHATSAPP=5548999326792
NEXT_PUBLIC_PHONE_CENTRO=+5548999326792
NEXT_PUBLIC_PHONE_LAGUNA=+5548999095712
